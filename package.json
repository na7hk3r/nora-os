{
  "name": "nora-os",
  "private": true,
  "productName": "Nora OS",
  "version": "1.18.1",
  "description": "Nora OS - Modular Desktop App",
  "homepage": "https://na7hk3r.github.io/nora-os/",
  "repository": {
    "type": "git",
    "url": "https://github.com/na7hk3r/nora-os.git"
  },
  "author": "na7hk3r",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run desktop:dev",
    "build": "npm run desktop:build",
    "start": "npm run desktop:start",
    "typecheck": "npm run desktop:typecheck",
    "lint": "npm run desktop:lint",
    "lint:fix": "npm run desktop:lint:fix",
    "format": "npm run desktop:format",
    "format:check": "npm run desktop:format:check",
    "test": "npm run desktop:test",
    "test:watch": "npm run desktop:test:watch",
    "desktop:dev": "electron-vite dev",
    "desktop:build": "electron-vite build",
    "desktop:start": "electron-vite preview",
    "desktop:typecheck": "tsc --noEmit",
    "desktop:lint": "eslint \"apps/desktop/{src,electron}/**/*.{ts,tsx}\"",
    "desktop:lint:fix": "eslint \"apps/desktop/{src,electron}/**/*.{ts,tsx}\" --fix",
    "desktop:format": "prettier --write \"apps/desktop/{src,electron}/**/*.{ts,tsx,css,json}\"",
    "desktop:format:check": "prettier --check \"apps/desktop/{src,electron}/**/*.{ts,tsx,css,json}\"",
    "desktop:test": "vitest run --config apps/desktop/vitest.config.ts",
    "desktop:test:watch": "vitest --config apps/desktop/vitest.config.ts",
    "landing:dev": "npm --prefix apps/landing run dev",
    "landing:build": "npm --prefix apps/landing run build",
    "landing:typecheck": "npm --prefix apps/landing run typecheck",
    "landing:test": "npm --prefix apps/landing test",
    "mobile:test": "node tooling/automation/flutter-app.mjs test",
    "mobile:analyze": "node tooling/automation/flutter-app.mjs analyze",
    "create-plugin": "node scripts/create-plugin.mjs",
    "pack": "npm run desktop:build && electron-builder --dir",
    "dist": "npm run desktop:build && electron-builder",
    "dist:win": "npm run desktop:build && electron-builder --win",
    "release": "npm run desktop:build && electron-builder --publish always",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^7.3.2",
    "vitest": "^2.1.0"
  }
}
